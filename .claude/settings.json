      "Bash(corepack enable pnpm)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git merge-base:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(git switch:*)",
      "Bash(git symbolic-ref:*)",
      "Bash(git worktree *)",
      "Bash(mkdir -p .gaia/local/audit)",
      "Bash(mkdir -p .gaia/local/plans)",
      "Bash(pnpm build:*)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm format)",
      "Bash(pnpm install:*)",
      "Bash(pnpm lint)",
      "Bash(pnpm lint-dry)",
      "Bash(pnpm ls:*)",
      "Bash(pnpm outdated:*)",
      "Bash(pnpm pw-ui:*)",
      "Bash(pnpm pw:*)",
      "Bash(pnpm remove:*)",
      "Bash(pnpm storybook:*)",
      "Bash(pnpm stylelint)",
      "Bash(pnpm test:ci)",
      "Bash(pnpm test:ci:*)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm typecheck:*)",
      "Bash(rm -f .gaia/local/cache/gate1-*.json)",
      "Bash(rm -f .gaia/local/cache/shared/*)",
      "Bash(rm -f .gaia/local/handoff/HANDOFF-*.md)",
      "Bash(rm -rf .gaia/local/plans/*)",
      "Bash(rm -rf .gaia/local/specs/*)",
      "Bash(rm .gaia/local/handoff/HANDOFF-*.md)",
      "Edit(.claude/agents/**)",
      "Edit(.claude/commands/**)",
      "Edit(.claude/instructions/**)",
      "Edit(.claude/rules/**)",
      "Edit(.claude/skills/**)",
      "Edit(.gaia/**)",
      "Edit(.playwright/**)",
      "Edit(.storybook/**)",
      "Edit(CHANGELOG.md)",
      "Edit(app/**)",
      "Edit(public/**)",
      "Edit(test/**)",
      "Edit(wiki/**)",
      "WebFetch(domain:context7.com)",
      "Write(.gaia/local/audit/**)",
      "Write(.gaia/local/handoff/**)",
      "Write(.gaia/local/plans/**)",
      "Write(.gaia/local/specs/**)"
    ],
    "deny": [
      "Bash(git push --force-with-lease *main*)",
      "Bash(git push --force-with-lease *master*)",
      "Bash(git reset --hard HEAD~*)",
      "Edit(.env)",
      "Edit(.husky/_/**)",
      "Edit(pnpm-lock.yaml)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*credential*)",
      "Read(**/secrets/*)",
      "Read(.env)",
      "Write(.env)",
      "Write(pnpm-lock.yaml)"
