{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(corepack enable pnpm)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git merge-base:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(git switch:*)",
      "Bash(git symbolic-ref:*)",
      "Bash(git worktree *)",
      "Bash(pnpm build:*)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm format)",
      "Bash(pnpm install:*)",
      "Bash(pnpm lint)",
      "Bash(pnpm lint-dry)",
      "Bash(pnpm ls:*)",
      "Bash(pnpm outdated:*)",
      "Bash(pnpm remove:*)",
      "Bash(pnpm test:ci)",
      "Bash(pnpm test:ci:*)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm typecheck:*)",
      "Edit(.claude/agents/**)",
      "Edit(.claude/commands/**)",
      "Edit(.claude/instructions/**)",
      "Edit(.claude/rules/**)",
      "Edit(.claude/skills/**)",
      "Edit(CHANGELOG.md)",
      "Edit(app/**)",
      "Edit(public/**)",
      "Edit(test/**)",
      "WebFetch(domain:context7.com)"
    ],
    "deny": [
      "Bash(git push --force-with-lease *main*)",
      "Bash(git push --force-with-lease *master*)",
      "Bash(git reset --hard HEAD~*)",
      "Edit(.env)",
      "Edit(.husky/_/**)",
      "Edit(pnpm-lock.yaml)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*credential*)",
      "Read(**/secrets/*)",
      "Read(.env)",
      "Write(.env)",
      "Write(pnpm-lock.yaml)"
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  }
}
